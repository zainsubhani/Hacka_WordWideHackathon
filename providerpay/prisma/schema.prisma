// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Employer {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  creditBalance Int
  checkIns      CheckIn[]
  payments      Payment[]
  invoices      Invoice[]
  users         User[]
  loginTokens   LoginToken[]
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  employerId String
  employer   Employer  @relation(fields: [employerId], references: [id])
  role       String    @default("admin")
  createdAt  DateTime  @default(now())
  sessions   Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LoginToken {
  id          String    @id @default(cuid())
  token       String    @unique
  email       String
  employerId  String?
  employer    Employer? @relation(fields: [employerId], references: [id])
  companyName String?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model CheckIn {
  id             String       @id @default(cuid())
  employerId     String
  employer       Employer     @relation(fields: [employerId], references: [id])
  sliderValues   Json
  carryingText   String
  riskFlag       Boolean
  suggestionText String?
  satisfied      Boolean?
  createdAt      DateTime     @default(now())
  transaction    Transaction?
}

model Transaction {
  id         String    @id @default(cuid())
  checkInId  String    @unique
  checkIn    CheckIn   @relation(fields: [checkInId], references: [id])
  listenerId String?
  listener   Listener? @relation(fields: [listenerId], references: [id])
  replyText  String?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Listener {
  id           String        @id @default(cuid())
  name         String
  available    Boolean       @default(true)
  transactions Transaction[]
}

model Payment {
  id            String   @id @default(cuid())
  employerId    String
  employer      Employer @relation(fields: [employerId], references: [id])
  mollieId      String   @unique
  status        String
  creditsToAdd  Int
  amountValue   String   @default("10.00")
  createdAt     DateTime @default(now())
}

model Invoice {
  id           String   @id @default(cuid())
  employerId   String
  employer     Employer @relation(fields: [employerId], references: [id])
  periodStart  DateTime
  periodEnd    DateTime
  totalCredits Int
  totalAmount  String
  status       String   @default("draft")
  createdAt    DateTime @default(now())
}
